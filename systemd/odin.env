# odin runtime configuration

# Foot pedal — the keyboard interface of the PCsensor FootSwitch.
# `evtest` confirmed the pedal currently emits KEY_B (event code 48)
# on this interface when pressed.
ODIN_PEDAL_DEVICE=/dev/input/by-id/usb-PCsensor_FootSwitch-event-kbd
ODIN_PEDAL_KEYCODE=48

# mimir transcript stream
ODIN_MIMIR_HOST=127.0.0.1
ODIN_MIMIR_PORT=7200

# zerokb on the Pi Zero. Stays as a literal IP because the zerokb
# playbook intentionally disables avahi-daemon as part of the
# read-only-root minimization, so zero.local doesn't resolve. If
# your Pi is on a different IP, change this and `make deploy`.
ODIN_ZEROKB_HOST=192.168.10.8
ODIN_ZEROKB_PORT=7070

# Two-press cycle:
#
#   Press 1 → POST ODIN_SNAPSHOT_CAPTURE_URL — heimdall captures the
#             current frame and saves it to disk.
#   Press 2 → drain transcript buffer + send to zerokb. The typed
#             payload references ODIN_SNAPSHOT_VIEW_URL, which the
#             host's Claude Code curls to fetch the saved snapshot.
#
# CAPTURE_URL points at heimdall on localhost (we're on the same box).
# VIEW_URL is what gets typed into the host's Claude Code, so it has
# to be reachable from the host machine. We use agneta.local (mDNS
# name announced by avahi-daemon, installed by heimdall's playbook)
# instead of a literal IP — portable across LAN moves and DHCP
# renewals. If mDNS doesn't work in your environment, replace with
# the literal LAN IP of agneta.
ODIN_SNAPSHOT_CAPTURE_URL=http://127.0.0.1:7100/snapshot.png
ODIN_SNAPSHOT_VIEW_URL=http://agneta.local:7100/snapshot.png

# Debounce window in ms — pedal presses within this window of the
# previous one are ignored. Prevents accidental double-taps from
# advancing past press 1 immediately.
ODIN_PRESS_DEBOUNCE_MS=300

# Cap the transcript buffer to the last N lines, or 0 = unbounded.
# Default unbounded — mimir's VAD already skips silence so the
# buffer only grows during actual speech, not wall-clock time.
# Set to a positive number (e.g. 60 = ~5 minutes of speech) to
# enable a hard safety cap.
ODIN_BUFFER_MAX_LINES=0

# Optional payload header (blank by default — the transcript starts
# the message). Set to e.g. "MEETING CONTEXT:" if you want a label.
ODIN_PAYLOAD_HEADER=

# Footer that comes after the transcript and references the screenshot.
# {url} is replaced with ODIN_SNAPSHOT_VIEW_URL. Wrapped in parens
# so the URL reads as a parenthetical aside next to the transcript
# rather than a sentence in its own right.
ODIN_PAYLOAD_FOOTER=(screenshot for more context: {url})
